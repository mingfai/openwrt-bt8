+static int mt798x_2p5ge_phy_write_mmd(struct phy_device *phydev, int devnum,
+				       u16 regnum, u16 val)
+{
+	struct mii_bus *bus = phydev->mdio.bus;
+	int phy_addr = phydev->mdio.addr;
+	int ret;
+
+	/* Clause 45 indirect access via Clause 22 registers.
+	 * Bus lock is already held by the caller (__phy_write_mmd).
+	 */
+	__mdiobus_write(bus, phy_addr, MII_MMD_CTRL, devnum);
+	__mdiobus_write(bus, phy_addr, MII_MMD_DATA, regnum);
+	__mdiobus_write(bus, phy_addr, MII_MMD_CTRL,
+			devnum | MII_MMD_CTRL_NOINCR);
+	ret = __mdiobus_write(bus, phy_addr, MII_MMD_DATA, val);
+
+	/* The MT7988/MT7987 internal 2.5G PHY requires 7-8ms to process each
+	 * Clause 45 register write. Without this delay the PHY initializes
+	 * with corrupted registers and generates spurious TX Pause frames,
+	 * causing the link partner to stop sending traffic.
+	 */
+	usleep_range(7000, 8000);
+	return ret;
+}
